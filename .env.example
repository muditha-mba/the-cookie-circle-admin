# ─────────────────────────────────────────────────────────────
# THE COOKIE CIRCLE ADMIN — Environment Variables
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────

# Environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Application
NEXT_PUBLIC_APP_NAME="The Cookie Circle Admin"
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Map (order delivery location picker — optional overrides)
# Defaults to Kandy, Sri Lanka when unset.
# NEXT_PUBLIC_MAP_DEFAULT_LAT=7.2906
# NEXT_PUBLIC_MAP_DEFAULT_LNG=80.6337
# NEXT_PUBLIC_MAP_DEFAULT_ZOOM=13
# NEXT_PUBLIC_NOMINATIM_USER_AGENT="TheCookieCircleAdmin/1.0 (your-contact@example.com)"

# ── Staging example ───────────────────────────────────────────
# NEXT_PUBLIC_APP_ENV=staging
# NEXT_PUBLIC_APP_URL=https://admin-staging.thecookiecircle.lk
# NEXT_PUBLIC_API_URL=https://api-staging.thecookiecircle.lk

# ── Production example ──────────────────────────────────────────
# NEXT_PUBLIC_APP_ENV=production
# NEXT_PUBLIC_APP_URL=https://admin.thecookiecircle.lk
# NEXT_PUBLIC_API_URL=https://api.thecookiecircle.lk
